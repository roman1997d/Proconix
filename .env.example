# Copiază acest fișier ca .env și completează valorile.
# Nu comite .env în git (conține parole).

# ——— Baza de date PostgreSQL ———
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ProconixDB
DB_USER=postgres
# Obligatoriu pe VPS dacă PostgreSQL folosește parolă (SCRAM). Lăsat gol → erori de tip SASL / „client password must be a string”.
DB_PASSWORD=your_postgres_password_here

# Variante alternative (libpq): PGHOST, PGPORT, PGDATABASE, PGUSER, PGPASSWORD

# După deploy (local sau VPS), aliniază schema PostgreSQL cu aplicația:
#   npm run db:bootstrap
# Opțional, creează baza dacă lipsește:
#   BOOTSTRAP_CREATE_DB=1 npm run db:bootstrap
# Verificare tabele: npm run db:verify

# ——— Server ———
# PORT=3000
# HOST=localhost
