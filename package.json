{
  "name": "node_postgres_demo",
  "version": "1.0.0",
  "description": "Backend server demo",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:bootstrap": "bash scripts/bootstrap_database.sh",
    "db:verify": "bash scripts/verify_db_tables.sh",
    "lint": "eslint backend/ index.js server.js db.js",
    "lint:fix": "eslint backend/ index.js server.js db.js --fix",
    "audit:deps": "npm outdated && npm audit",
    "audit:all": "bash scripts/audit/run-all-audit.sh"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^2.0.2",
    "nodemailer": "^6.9.16",
    "pdfkit": "^0.16.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "nodemon": "^3.0.2"
  }
}
